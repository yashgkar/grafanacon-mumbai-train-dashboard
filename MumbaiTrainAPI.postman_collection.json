    {
      "name": "4 · Train Frequency (Stat panel)",
      "item": [
        {
          "name": "GET /trains/frequency — OK",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": { "raw": "{{base_url}}/trains/frequency", "host": ["{{base_url}}"], "path": ["trains","frequency"] },
            "description": "AC vs Non-AC trains per hour. Infinity: JSON array, stat panel — one tile per row."
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",

            "pm.test('6 rows: 3 lines × 2 types', () => {",
            "    pm.expect(pm.response.json()).to.be.an('array').with.lengthOf(6);",
            "});",

            "pm.test('type is AC or Non-AC', () => {",
            "    pm.response.json().forEach(r => {",
            "        pm.expect(['AC','Non-AC']).to.include(r.type);",
            "    });",
            "});",

            "pm.test('trains_per_hour is a positive number', () => {",
            "    pm.response.json().forEach(r => {",
            "        pm.expect(r.trains_per_hour).to.be.a('number').and.above(0);",
            "    });",
            "});",

            "pm.test('avg_interval_min is positive', () => {",
            "    pm.response.json().forEach(r => {",
            "        pm.expect(r.avg_interval_min).to.be.a('number').and.above(0);",
            "    });",
            "});",

            "pm.test('Non-AC always higher frequency than AC per line', () => {",
            "    const json = pm.response.json();",
            "    ['Central','Western','Harbour'].forEach(line => {",
            "        const ac    = json.find(r => r.line === line && r.type === 'AC');",
            "        const nonac = json.find(r => r.line === line && r.type === 'Non-AC');",
            "        if (ac && nonac) pm.expect(nonac.trains_per_hour).to.be.above(ac.trains_per_hour);",
            "    });",
            "});"
          ]}}]
        },
