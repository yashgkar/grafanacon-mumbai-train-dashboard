{
  "info": {
    "name": "Mumbai Local Train API",
    "_postman_id": "mumbai-train-api-collection-v1",
    "description": "Test collection for the Mumbai Local Train Grafana Infinity dashboard API.\n\n**Variables to set:**\n- `base_url` → your Lambda URL or `http://localhost:8000`\n- `api_key` → your secret key (default: `mumbai-train-secret`)\n\nRun the full suite via Collection Runner to validate all endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "description": "Base API URL. No trailing slash." },
    { "key": "api_key",  "value": "mumbai-train-secret",  "description": "X-API-Key header value." }
  ],
  "item": [

    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health — OK",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('status = ok', () => pm.expect(pm.response.json().status).to.eql('ok'));",
            "pm.test('has timestamp', () => pm.expect(new Date(pm.response.json().timestamp).toString()).to.not.eql('Invalid Date'));",
            "pm.test('response < 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));"
          ]}}]
        }
      ]
    },

    {
      "name": "1 · Line Status (Stat panel)",
      "item": [
        {
          "name": "GET /lines/status — OK",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": { "raw": "{{base_url}}/lines/status", "host": ["{{base_url}}"], "path": ["lines","status"] },
            "description": "Returns one object per line. Grafana Infinity: JSON array, stat panel, color via value mappings on status_code."
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",

            "pm.test('Returns exactly 3 lines', () => {",
            "    const json = pm.response.json();",
            "    pm.expect(json).to.be.an('array').with.lengthOf(3);",
            "});",

            "pm.test('All 3 lines present', () => {",
            "    const names = pm.response.json().map(l => l.line);",
            "    ['Central','Western','Harbour'].forEach(l => pm.expect(names).to.include(l));",
            "});",

            "pm.test('status is one of normal/delay/disrupted', () => {",
            "    pm.response.json().forEach(l => {",
            "        pm.expect(['normal','delay','disrupted']).to.include(l.status);",
            "    });",
            "});",

            "pm.test('status_code matches status', () => {",
            "    const map = {normal:0, delay:1, disrupted:2};",
            "    pm.response.json().forEach(l => {",
            "        pm.expect(l.status_code).to.eql(map[l.status]);",
            "    });",
            "});",

            "pm.test('delay_minutes is 0 when normal', () => {",
            "    pm.response.json().filter(l => l.status === 'normal').forEach(l => {",
            "        pm.expect(l.delay_minutes).to.eql(0);",
            "    });",
            "});",

            "pm.test('delay_minutes > 0 when not normal', () => {",
            "    pm.response.json().filter(l => l.status !== 'normal').forEach(l => {",
            "        pm.expect(l.delay_minutes).to.be.above(0);",
            "    });",
            "});",

            "pm.test('has required fields', () => {",
            "    const keys = ['line','status','status_code','delay_minutes','trains_running','updated_at'];",
            "    pm.response.json().forEach(l => keys.forEach(k => pm.expect(l).to.have.property(k)));",
            "});"
          ]}}]
        },
        {
          "name": "GET /lines/status — FAIL: no API key",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/lines/status", "host": ["{{base_url}}"], "path": ["lines","status"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "pm.test('detail field present', () => pm.expect(pm.response.json()).to.have.property('detail'));"
          ]}}]
        },
        {
          "name": "GET /lines/status — FAIL: wrong API key",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "wrong-key" }],
            "url": { "raw": "{{base_url}}/lines/status", "host": ["{{base_url}}"], "path": ["lines","status"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));",
            "pm.test('not a lines array', () => pm.expect(pm.response.json()).to.not.be.an('array'));"
          ]}}]
        }
      ]
    },

    {
      "name": "2 · Train Count (Bar gauge)",
      "item": [
        {
          "name": "GET /trains/count — OK",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": { "raw": "{{base_url}}/trains/count", "host": ["{{base_url}}"], "path": ["trains","count"] },
            "description": "Running vs halted per line. Infinity: JSON, bar gauge on running + halted fields."
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",

            "pm.test('3 lines returned', () => {",
            "    pm.expect(pm.response.json()).to.be.an('array').with.lengthOf(3);",
            "});",

            "pm.test('running + halted = total', () => {",
            "    pm.response.json().forEach(l => {",
            "        pm.expect(l.running + l.halted).to.eql(l.total);",
            "    });",
            "});",

            "pm.test('pct_running is 0-100', () => {",
            "    pm.response.json().forEach(l => {",
            "        pm.expect(l.pct_running).to.be.within(0, 100);",
            "    });",
            "});",

            "pm.test('halted is always < running', () => {",
            "    pm.response.json().forEach(l => {",
            "        pm.expect(l.halted).to.be.below(l.running);",
            "    });",
            "});",

            "pm.test('has required fields', () => {",
            "    const keys = ['line','running','halted','total','pct_running'];",
            "    pm.response.json().forEach(l => keys.forEach(k => pm.expect(l).to.have.property(k)));",
            "});"
          ]}}]
        },
        {
          "name": "GET /trains/count — FAIL: no API key",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/trains/count", "host": ["{{base_url}}"], "path": ["trains","count"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ]}}]
        }
      ]
    },

    {
      "name": "3 · Crowd Heatmap (Heatmap panel)",
      "item": [
        {
          "name": "GET /crowd/heatmap — defaults (12h all lines)",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/crowd/heatmap",
              "host": ["{{base_url}}"], "path": ["crowd","heatmap"]
            },
            "description": "Time-series shape for Infinity heatmap.\nInfinity config: Format=Time series, Timestamp=timestamp, Value=density, Group by=zone.\nEach zone becomes one series → heatmap rows. Grafana auto-buckets by timestamp."
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",

            "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));",

            "pm.test('Exactly 5 zones × 12 hours = 60 data points', () => {",
            "    pm.expect(pm.response.json()).to.have.lengthOf(60);",
            "});",

            "pm.test('All 5 zones present', () => {",
            "    const zones = [...new Set(pm.response.json().map(r => r.zone))];",
            "    pm.expect(zones).to.have.lengthOf(5);",
            "    ['Zone 1','Zone 2','Zone 3','Zone 4','Zone 5'].forEach(z => pm.expect(zones).to.include(z));",
            "});",

            "pm.test('density is 0-100', () => {",
            "    pm.response.json().forEach(r => {",
            "        pm.expect(r.density).to.be.a('number').and.within(0, 100);",
            "    });",
            "});",

            "pm.test('timestamps are valid ISO dates', () => {",
            "    pm.response.json().forEach(r => {",
            "        pm.expect(new Date(r.timestamp).toString()).to.not.eql('Invalid Date');",
            "    });",
            "});",

            "pm.test('data is sorted chronologically', () => {",
            "    const json = pm.response.json();",
            "    for (let i = 1; i < json.length; i++) {",
            "        const prev = new Date(json[i-1].timestamp);",
            "        const curr = new Date(json[i].timestamp);",
            "        pm.expect(curr.getTime()).to.be.at.least(prev.getTime());",
            "    }",
            "});",

            "pm.test('has required fields per row', () => {",
            "    const keys = ['timestamp','zone','density','line'];",
            "    pm.response.json().forEach(r => keys.forEach(k => pm.expect(r).to.have.property(k)));",
            "});"
          ]}}]
        },
